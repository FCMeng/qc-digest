<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Quantum Computing Digest</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f7f4;
        --ink: #18201d;
        --muted: #5d6862;
        --line: #d8ded9;
        --paper: #ffffff;
        --accent: #0d766e;
        --accent-2: #9a5b13;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ink);
        background: var(--bg);
        line-height: 1.5;
      }
      header {
        border-bottom: 1px solid var(--line);
        background: var(--paper);
      }
      .wrap {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
      }
      .mast {
        padding: 36px 0 28px;
      }
      h1 {
        margin: 0 0 8px;
        font-size: clamp(2rem, 5vw, 3.8rem);
        line-height: 1.05;
        font-weight: 760;
        letter-spacing: 0;
      }
      .meta {
        color: var(--muted);
        margin: 0;
        font-size: 0.98rem;
      }
      .page {
        display: grid;
        grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
        gap: 24px;
        padding: 28px 0 48px;
      }
      aside {
        align-self: start;
        position: sticky;
        top: 16px;
      }
      nav {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 14px;
      }
      nav h2 {
        margin-bottom: 10px;
      }
      .archive-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 6px;
      }
      .archive-date {
        margin: 12px 0 4px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 750;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .archive-list a {
        display: block;
        border-radius: 6px;
        padding: 8px 10px;
        color: var(--ink);
        text-decoration: none;
        font-weight: 650;
      }
      .archive-list a:hover,
      .archive-list a.active {
        background: #e7efec;
        color: var(--accent);
      }
      details.more-runs {
        margin-top: 10px;
        border-top: 1px solid var(--line);
        padding-top: 10px;
      }
      details.more-runs summary {
        cursor: pointer;
        color: var(--accent);
        font-weight: 750;
        list-style: none;
      }
      details.more-runs summary::-webkit-details-marker {
        display: none;
      }
      section {
        margin-top: 0;
      }
      section + section {
        margin-top: 30px;
      }
      h2 {
        margin: 0 0 14px;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
        gap: 14px;
      }
      article {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
      }
      article h3 {
        margin: 0 0 10px;
        font-size: 1.08rem;
        line-height: 1.3;
        letter-spacing: 0;
      }
      article p {
        margin: 10px 0 0;
      }
      .item-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        color: var(--muted);
        font-size: 0.88rem;
      }
      .tag {
        color: #fff;
        background: var(--accent);
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .tag.news {
        background: var(--accent-2);
      }
      a {
        color: var(--accent);
        font-weight: 650;
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }
      .empty {
        color: var(--muted);
        border: 1px dashed var(--line);
        padding: 18px;
        border-radius: 8px;
      }
      footer {
        color: var(--muted);
        border-top: 1px solid var(--line);
        padding: 24px 0;
        font-size: 0.9rem;
      }
      @media (max-width: 760px) {
        .page {
          grid-template-columns: 1fr;
        }
        aside {
          position: static;
        }
        .archive-list {
          grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="wrap mast">
        <h1>Quantum Computing Digest</h1>
        <p class="meta">Generated {{ generated_at }}. Top {{ items|length }} LLM-selected papers and news items.</p>
      </div>
    </header>

    <main class="wrap page">
      <aside>
        <nav aria-label="Archived pipeline runs">
          <h2>Runs</h2>
          {% if archives %}
          <ul class="archive-list">
            {% set ns = namespace(last_date='') %}
            {% for archive in visible_archives %}
            {% if archive.display_date != ns.last_date %}
            <li class="archive-date">{{ archive.display_date }}</li>
            {% set ns.last_date = archive.display_date %}
            {% endif %}
            <li>
              <a class="{% if archive.slug == active_archive_slug %}active{% endif %}" href="{{ archive.url }}" title="{{ archive.title }}">{{ archive.display_time }}</a>
            </li>
            {% endfor %}
          </ul>
          {% if older_archives %}
          <details class="more-runs">
            <summary>More runs</summary>
            <ul class="archive-list">
              {% set older = namespace(last_date='') %}
              {% for archive in older_archives %}
              {% if archive.display_date != older.last_date %}
              <li class="archive-date">{{ archive.display_date }}</li>
              {% set older.last_date = archive.display_date %}
              {% endif %}
              <li>
                <a class="{% if archive.slug == active_archive_slug %}active{% endif %}" href="{{ archive.url }}" title="{{ archive.title }}">{{ archive.display_time }}</a>
              </li>
              {% endfor %}
            </ul>
          </details>
          {% endif %}
          {% else %}
          <p class="meta">No archived runs yet.</p>
          {% endif %}
        </nav>
      </aside>

      <div>
        <section>
          <h2>Papers</h2>
          {% if grouped.papers %}
          <div class="grid">
            {% for item in grouped.papers %}
            <article>
              <div class="item-meta">
                <span class="tag">Paper</span>
                <span>{{ item.source }}</span>
                {% if item.published_date %}<span>{{ item.published_date }}</span>{% endif %}
                <span>Score {{ "%.1f"|format(item.score) }}</span>
              </div>
              <h3>{{ item.title }}</h3>
              <p>{{ item.summary }}</p>
              <p><strong>Why selected:</strong> {{ item.why_selected }}</p>
              <p><a href="{{ item.url }}">Original link</a></p>
            </article>
            {% endfor %}
          </div>
          {% else %}
          <p class="empty">No papers selected in this run.</p>
          {% endif %}
        </section>

        <section>
          <h2>News</h2>
          {% if grouped.news %}
          <div class="grid">
            {% for item in grouped.news %}
            <article>
              <div class="item-meta">
                <span class="tag news">News</span>
                <span>{{ item.source }}</span>
                {% if item.published_date %}<span>{{ item.published_date }}</span>{% endif %}
                <span>Score {{ "%.1f"|format(item.score) }}</span>
              </div>
              <h3>{{ item.title }}</h3>
              <p>{{ item.summary }}</p>
              <p><strong>Why selected:</strong> {{ item.why_selected }}</p>
              <p><a href="{{ item.url }}">Original link</a></p>
            </article>
            {% endfor %}
          </div>
          {% else %}
          <p class="empty">No news selected in this run.</p>
          {% endif %}
        </section>
      </div>
    </main>

    <footer>
      <div class="wrap">Published at <a href="{{ pages_url }}">{{ pages_url }}</a></div>
    </footer>
  </body>
</html>
