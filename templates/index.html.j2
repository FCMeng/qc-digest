<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Research Digest</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f7f4;
        --ink: #18201d;
        --muted: #5d6862;
        --line: #d8ded9;
        --paper: #ffffff;
        --accent: #0d766e;
        --accent-2: #9a5b13;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ink);
        background: var(--bg);
        line-height: 1.5;
      }
      header {
        border-bottom: 1px solid var(--line);
        background: var(--paper);
      }
      .wrap {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
      }
      .mast {
        padding: 36px 0 28px;
      }
      h1 {
        margin: 0 0 8px;
        font-size: clamp(2rem, 5vw, 3.8rem);
        line-height: 1.05;
        font-weight: 760;
        letter-spacing: 0;
      }
      .meta {
        color: var(--muted);
        margin: 0;
        font-size: 0.98rem;
      }
      .tabs {
        display: grid;
        gap: 18px;
      }
      .tab-options {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        width: fit-content;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 4px;
      }
      .tab-options label {
        cursor: pointer;
        border-radius: 6px;
        padding: 8px 12px;
        font-weight: 750;
        color: var(--muted);
      }
      input[name="track-tab"] {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      .track-panel {
        display: none;
        min-width: 0;
      }
      {% for section in track_sections %}
      #tab-{{ section.key }}:checked ~ .tab-options label[for="tab-{{ section.key }}"] {
        background: #e7efec;
        color: var(--accent);
      }
      #tab-{{ section.key }}:checked ~ .panel-{{ section.key }} {
        display: grid;
        gap: 30px;
      }
      {% endfor %}
      .page {
        display: grid;
        grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
        gap: 24px;
        padding: 28px 0 48px;
      }
      .content {
        min-width: 0;
      }
      aside {
        align-self: start;
        position: sticky;
        top: 16px;
      }
      nav {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 14px;
      }
      nav h2 {
        margin-bottom: 10px;
      }
      .archive-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 6px;
      }
      .archive-date {
        margin: 12px 0 4px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 750;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .archive-list a {
        display: block;
        border-radius: 6px;
        padding: 8px 10px;
        color: var(--ink);
        text-decoration: none;
        font-weight: 650;
      }
      .archive-list a:hover,
      .archive-list a.active {
        background: #e7efec;
        color: var(--accent);
      }
      details.more-runs {
        margin-top: 10px;
        border-top: 1px solid var(--line);
        padding-top: 10px;
      }
      details.more-runs summary {
        cursor: pointer;
        color: var(--accent);
        font-weight: 750;
        list-style: none;
      }
      details.more-runs summary::-webkit-details-marker {
        display: none;
      }
      section {
        margin-top: 0;
      }
      h2 {
        margin: 0 0 14px;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
        gap: 14px;
        min-width: 0;
      }
      article {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        min-width: 0;
        overflow-wrap: anywhere;
      }
      article h3 {
        margin: 0 0 10px;
        font-size: 1.08rem;
        line-height: 1.3;
        letter-spacing: 0;
      }
      article p {
        margin: 10px 0 0;
      }
      .item-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        color: var(--muted);
        font-size: 0.88rem;
      }
      .tag {
        color: #fff;
        background: var(--accent);
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .tag.news {
        background: var(--accent-2);
      }
      .category {
        color: var(--accent);
        border: 1px solid #8ac2bb;
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.76rem;
        font-weight: 750;
      }
      a {
        color: var(--accent);
        font-weight: 650;
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }
      .empty {
        color: var(--muted);
        border: 1px dashed var(--line);
        padding: 18px;
        border-radius: 8px;
      }
      footer {
        color: var(--muted);
        border-top: 1px solid var(--line);
        padding: 24px 0;
        font-size: 0.9rem;
      }
      @media (max-width: 760px) {
        .page {
          grid-template-columns: 1fr;
        }
        aside {
          position: static;
        }
        .archive-list {
          grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="wrap mast">
        <h1>Research Digest</h1>
        <p class="meta">Generated {{ generated_at }}. Current digest includes {{ item_count }} selected items.</p>
      </div>
    </header>

    <main class="wrap page">
      <aside>
        <nav aria-label="Archived pipeline runs">
          <h2>Runs</h2>
          {% if archives %}
          <ul class="archive-list">
            {% set ns = namespace(last_date='') %}
            {% for archive in visible_archives %}
            {% if archive.display_date != ns.last_date %}
            <li class="archive-date">{{ archive.display_date }}</li>
            {% set ns.last_date = archive.display_date %}
            {% endif %}
            <li>
              <a class="{% if archive.slug == active_archive_slug %}active{% endif %}" href="{{ archive.url }}" title="{{ archive.title }}">{{ archive.display_time }}</a>
            </li>
            {% endfor %}
          </ul>
          {% if older_archives %}
          <details class="more-runs">
            <summary>More runs</summary>
            <ul class="archive-list">
              {% set older = namespace(last_date='') %}
              {% for archive in older_archives %}
              {% if archive.display_date != older.last_date %}
              <li class="archive-date">{{ archive.display_date }}</li>
              {% set older.last_date = archive.display_date %}
              {% endif %}
              <li>
                <a class="{% if archive.slug == active_archive_slug %}active{% endif %}" href="{{ archive.url }}" title="{{ archive.title }}">{{ archive.display_time }}</a>
              </li>
              {% endfor %}
            </ul>
          </details>
          {% endif %}
          {% else %}
          <p class="meta">No archived runs yet.</p>
          {% endif %}
        </nav>
      </aside>

      <div class="content">
        <div class="tabs">
          {% for section in track_sections %}
          <input id="tab-{{ section.key }}" type="radio" name="track-tab" {% if loop.first %}checked{% endif %}>
          {% endfor %}
          <div class="tab-options">
            {% for section in track_sections %}
            <label for="tab-{{ section.key }}">{{ section.label }}</label>
            {% endfor %}
          </div>

          {% for section in track_sections %}
          <div class="track-panel panel-{{ section.key }}">
            {% if section.key == 'opportunities' %}
            <section>
              <h2>Opportunities</h2>
              {% if section.opportunities %}
              <div class="grid">
                {% for item in section.opportunities %}
                <article>
                  <div class="item-meta">
                    <span class="tag">{{ item.topic_tag }}</span>
                    <span class="category">{{ item.event_tag }}</span>
                    {% if item.deadline %}<span class="category">Deadline {{ item.deadline }}</span>{% endif %}
                  </div>
                  <h3>{{ item.title }}</h3>
                  <p>{{ item.summary }}</p>
                  {% if item.event_date %}<p><strong>Event date:</strong> {{ item.event_date }}</p>{% endif %}
                  <p><a href="{{ item.url }}">Original link</a></p>
                </article>
                {% endfor %}
              </div>
              {% else %}
              <p class="empty">No opportunities selected in this run.</p>
              {% endif %}
            </section>
            {% else %}
            <section>
              <h2>Papers</h2>
              {% if section.grouped.papers %}
              <div class="grid">
                {% for item in section.grouped.papers %}
                <article>
                  <div class="item-meta">
                    <span class="tag">Paper</span>
                    {% if item.category %}<span class="category">{{ item.category }}</span>{% endif %}
                  </div>
                  <h3>{{ item.title }}</h3>
                  <p>{{ item.summary }}</p>
                  <p><strong>Why selected:</strong> {{ item.why_selected }}</p>
                  <p><a href="{{ item.url }}">Original link</a></p>
                </article>
                {% endfor %}
              </div>
              {% else %}
              <p class="empty">No papers selected in this run.</p>
              {% endif %}
            </section>

            <section>
              <h2>News</h2>
              {% if section.grouped.news %}
              <div class="grid">
                {% for item in section.grouped.news %}
                <article>
                  <div class="item-meta">
                    <span class="tag news">News</span>
                  </div>
                  <h3>{{ item.title }}</h3>
                  <p>{{ item.summary }}</p>
                  <p><strong>Why selected:</strong> {{ item.why_selected }}</p>
                  <p><a href="{{ item.url }}">Original link</a></p>
                </article>
                {% endfor %}
              </div>
              {% else %}
              <p class="empty">No news selected in this run.</p>
              {% endif %}
            </section>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
    </main>

    <footer>
      <div class="wrap">Published at <a href="{{ pages_url }}">{{ pages_url }}</a></div>
    </footer>
  </body>
</html>
